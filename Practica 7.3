6. Configuración de Kerberos
----------------------------
cp /usr/local/samba/private/krb5.conf /etc/krb5.conf 
o 
sudo cp /usr/local/samba/var/lib/samba/private/krb5.conf /etc/krb5.conf

#Servico systemctl:
sudo nano /etc/systemd/system/samba-ad-dc.service

[Unit]
Description=Samba AD DC
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/samba/sbin/samba -i

[Install]
WantedBy=multi-user.target
======================

Crear el directorio
sudo mkdir -p /srv/samba/compartido_dominio

# IMPORTANTE: El grupo "Domain Users" lleva un espacio. 
# En Linux, para que el comando chown funcione con espacios, se usa así:
sudo chown :"Domain Users" /srv/samba/compartido_dominio

# Permisos totales para el grupo del dominio
sudo chmod 770 /srv/samba/compartido_dominio

Permitir que Samba exporte carpetas con lectura/escritura
sudo setsebool -P samba_export_all_rw on

# Etiquetar la carpeta para que Samba tenga acceso
sudo chcon -t samba_share_t /srv/samba/compartido_dominio

sudo nano /usr/local/samba/etc/smb.conf  :Agregamos al final:
[CompartidoAD]
    path = /srv/samba/compartido_dominio
    read only = no
    browsable = yes
    create mask = 0775
    directory mask = 0775
    admin users = OS3\Administrator
    
    =============================

#Iniciar servicio
sudo setenforce 0
sudo systemctl daemon-reload
sudo systemctl enable --now samba-ad-dc

Agregar reglas de firewall
firewall-cmd --permanent --add-service={ldap,ldaps,kerberos,dns}
firewall-cmd --permanent --add-port={53,88,135,139,389,445,464,636,3268,3269}/tcp
firewall-cmd --permanent --add-port={53,88,123,138,389,464}/udp
firewall-cmd --reload

7.Configurar el DNS para que sea solo la ip del sevidor y aplicamos el cambio:
sudo nmcli con mod ens160 ipv4.dns 192.168.1.78
sudo nmcli con mod ens160 ipv4.ignore-auto-dns yes
sudo nmcli con up ens160


Agregar regisrto DN maquina cliente
samba-tool dns add 192.168.1.78 OS3.inet www A 192.168.1.77 -U Administrator 


