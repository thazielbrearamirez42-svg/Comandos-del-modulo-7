Laboratorio 7.2 :Creación de fileserver compatible con windows
 
#Instalar y habilitar SAMBA (Servidor Linux)
sudo dnf install samba samba-common samba-client -y

#Habilitar servicios de smb:
sudo systemctl enable --now smb
sudo systemctl status smb

# Crear carpeta compartida
sudo mkdir -p /srv/samba/os3

# Crear archivos requeridos y asignar permisos necesarios:
sudo chcon -R -t samba_share_t /srv/samba/os3
cd /srv/samba/os3
sudo touch adrian{1..100}.txt 
sudo chown -R tbrea:os3grupo /srv/samba/os3
sudo chmod -R 770 /srv/samba/os3
ls
#Configurar firewall 
sudo firewall-cmd --add-service=samba --permanent
sudo firewall-cmd --reload

#Configurar SAMBA: sudo nano /etc/samba/smb.conf
Agrega al final:
[OS3]
path = /srv/samba/os3
valid users = tbrea
read only = no
browsable = yes

#Extra:
[OS3]
    comment = Repositorio de Laboratorio
    path = /srv/samba/os3
    valid users = tbrea
    public = no
    writable = yes
    browsable = yes
    guest ok = no
    create mask = 0660
    directory mask = 0770

    
 
#Crear grupo y usuario en samba
sudo groupadd os3grupo
sudo useradd -M -s /sbin/nologin tbrea
sudo smbpasswd -a tbrea
sudo usermod -aG os3grupo tbrea

# Extra:
sudo smbpasswd -a tbrea

# Luego aplicas los permisos a la carpeta
sudo chown -R tbrea:os3grupo /srv/samba/os3
sudo chmod -R 770 /srv/samba/os3


ls -ld /srv/samba/os3

 #Reiniciar servicio
sudo systemctl restart smb

